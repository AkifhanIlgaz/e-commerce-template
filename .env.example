# --- HTTP ---
ADDR=:8080
APP_ENV=dev            # dev | prod (prod: Secure cookie zorunlu, default admin şifresi reddedilir)

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ecommerce

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Session ---
SESSION_IDLE_TIMEOUT=30m
SESSION_ABSOLUTE_TIMEOUT=12h

# --- İlk admin kullanıcısı (ilk açılışta otomatik oluşturulur) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# --- Payment (provider'a göre doldur, kod değişmez) ---
PAYMENT_PROVIDER=mock  # mock | (ileride: iyzico, stripe, ...)
PAYMENT_API_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_BASE_URL=

# --- Storefront marka ---
STORE_NAME=Demo Store
